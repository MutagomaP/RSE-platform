<!-- HERO -->
<section class="hero">
  <div class="container hero-content">
    <p class="hero-eyebrow">🇷🇼 Rwanda Capital Markets</p>
    <h1>Trade Rwanda's<br>Listed Securities</h1>
    <p class="hero-sub">
      Connect directly with licensed RSE brokers. Buy and sell equities, bonds, and ETFs
      listed on the Rwanda Stock Exchange — all in one secure platform.
    </p>
    <div class="hero-actions">
      <a href="/auth/register" class="btn btn-primary btn-lg">Open Free Account</a>
      <a href="/market" class="btn btn-ghost btn-lg">View Live Market →</a>
    </div>
    <div class="hero-stats">
      <div>
        <div class="hero-stat-value">{{#if market}}{{market.breadth.total}}{{else}}15{{/if}}</div>
        <div class="hero-stat-label">Listed Securities</div>
      </div>
      <div>
        <div class="hero-stat-value">RWF {{#if market}}{{#if market.totalMarketCap}}{{market.totalMarketCap}}{{else}}6.2T{{/if}}{{else}}6.2T{{/if}}</div>
        <div class="hero-stat-label">Total Market Cap</div>
      </div>
      <div>
        <div class="hero-stat-value">{{#if brokers}}{{brokers.length}}{{else}}8{{/if}}</div>
        <div class="hero-stat-label">Licensed Brokers</div>
      </div>
      <div>
        <div class="hero-stat-value">T+2</div>
        <div class="hero-stat-label">Settlement Cycle</div>
      </div>
    </div>
  </div>
</section>

<!-- TICKER STRIP -->
{{#if market}}
<div class="ticker-strip">
  <div class="ticker-inner" id="tickerInner">
    {{#each market.gainers}}
    <div class="ticker-item">
      <span class="ticker-symbol">{{this.ticker}}</span>
      <span class="ticker-price">{{formatCurrency this.currentPrice ''}}</span>
      <span class="ticker-change up">▲ {{abs this.changePct}}%</span>
    </div>
    {{/each}}
    {{#each market.losers}}
    <div class="ticker-item">
      <span class="ticker-symbol">{{this.ticker}}</span>
      <span class="ticker-price">{{formatCurrency this.currentPrice ''}}</span>
      <span class="ticker-change down">▼ {{abs this.changePct}}%</span>
    </div>
    {{/each}}
    <!-- duplicate for infinite scroll -->
    {{#each market.gainers}}
    <div class="ticker-item">
      <span class="ticker-symbol">{{this.ticker}}</span>
      <span class="ticker-price">{{formatCurrency this.currentPrice ''}}</span>
      <span class="ticker-change up">▲ {{abs this.changePct}}%</span>
    </div>
    {{/each}}
  </div>
</div>
{{/if}}

<!-- MARKET INDICES -->
{{#if market}}
<section class="section-sm" style="background:var(--neutral-50); border-bottom:1px solid var(--neutral-100);">
  <div class="container">
    <div class="grid-3">
      {{#each market.indices}}
      <div class="index-card">
        <div class="index-name">{{@key}}</div>
        <div class="index-value {{#if (positive this.change)}}positive{{else}}negative{{/if}}">{{this.value}}</div>
        <div class="index-change {{#if (positive this.change)}}positive{{else}}negative{{/if}}">
          {{#if (positive this.change)}}▲{{else}}▼{{/if}} {{abs this.change}}%
        </div>
        <div class="index-currency">{{this.currency}}</div>
      </div>
      {{/each}}
    </div>
  </div>
</section>
{{/if}}

<!-- TOP SECURITIES TABLE -->
<section class="section">
  <div class="container">
    <div class="flex-between mb-3">
      <div class="section-header" style="margin-bottom:0">
        <h2>Listed Securities</h2>
        <p>Equities, bonds and ETFs trading on the RSE</p>
      </div>
      <a href="/securities" class="btn btn-secondary btn-sm">View All →</a>
    </div>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead>
            <tr>
              <th>Ticker</th>
              <th>Company</th>
              <th>Sector</th>
              <th class="text-right">Price (RWF)</th>
              <th class="text-right">Change</th>
              <th class="text-right">Volume</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            {{#each securities}}
            <tr>
              <td><span class="ticker-badge">{{this.ticker}}</span></td>
              <td class="fw-600">{{this.companyName}}</td>
              <td class="text-muted text-sm">{{this.sector}}</td>
              <td class="text-right price-cell">{{formatCurrency this.currentPrice ''}}</td>
              <td class="text-right">
                {{#if this.previousClose}}
                  {{#if (positive (gt this.currentPrice this.previousClose))}}
                  <span class="change-cell up">▲ {{abs this.changePct}}%</span>
                  {{else}}
                  <span class="change-cell down">▼ {{abs this.changePct}}%</span>
                  {{/if}}
                {{else}}
                  <span class="text-muted">—</span>
                {{/if}}
              </td>
              <td class="text-right text-sm text-muted">{{this.volume}}</td>
              <td><a href="/securities/{{this.id}}" class="btn btn-secondary btn-sm">Trade</a></td>
            </tr>
            {{else}}
            <tr><td colspan="7" class="text-center text-muted" style="padding:2rem">No securities listed yet</td></tr>
            {{/each}}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>

<!-- HOW IT WORKS -->
<section class="section" style="background:var(--green-900);">
  <div class="container">
    <div class="section-header centered" style="color:white">
      <h2 style="color:white">How It Works</h2>
      <p style="color:var(--green-200)">Three simple steps to start investing in Rwanda's capital markets</p>
    </div>
    <div class="grid-3" style="margin-top:2rem">
      <div style="text-align:center;padding:2rem;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:12px;">
        <div style="font-size:2.5rem;margin-bottom:1rem;">🏦</div>
        <h3 style="color:white;margin-bottom:0.5rem">1. Open Account</h3>
        <p style="color:var(--green-200);font-size:0.9rem">Register and verify your identity. Get your CSD account number linked.</p>
      </div>
      <div style="text-align:center;padding:2rem;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:12px;">
        <div style="font-size:2.5rem;margin-bottom:1rem;">🤝</div>
        <h3 style="color:white;margin-bottom:0.5rem">2. Choose a Broker</h3>
        <p style="color:var(--green-200);font-size:0.9rem">Browse licensed RSE brokers and connect with one to execute your trades.</p>
      </div>
      <div style="text-align:center;padding:2rem;background:rgba(255,255,255,0.05);border:1px solid rgba(255,255,255,0.1);border-radius:12px;">
        <div style="font-size:2.5rem;margin-bottom:1rem;">📈</div>
        <h3 style="color:white;margin-bottom:0.5rem">3. Buy & Sell</h3>
        <p style="color:var(--green-200);font-size:0.9rem">Place buy or sell orders. Trades settle in T+2 business days via CSD Rwanda.</p>
      </div>
    </div>
    <div style="text-align:center;margin-top:2.5rem">
      <a href="/auth/register" class="btn btn-primary btn-lg">Get Started Free</a>
    </div>
  </div>
</section>

<!-- LICENSED BROKERS -->
<section class="section">
  <div class="container">
    <div class="flex-between mb-3">
      <div class="section-header" style="margin-bottom:0">
        <h2>Licensed Brokers</h2>
        <p>CMA-licensed broker firms on the RSE platform</p>
      </div>
      <a href="/brokers" class="btn btn-secondary btn-sm">View All Brokers →</a>
    </div>
    <div class="grid-3">
      {{#each brokers}}
      <div class="broker-card">
        <div class="broker-name">{{this.firmName}}</div>
        <div class="broker-license">License: {{this.licenseNumber}} · <span class="badge badge-success">Licensed</span></div>
        <p class="broker-desc">{{truncate this.description 80}}</p>
        <div class="broker-meta">
          <div class="broker-meta-item">
            <div class="broker-meta-val">{{this.commissionRate}}%</div>
            <div class="broker-meta-lbl">Commission</div>
          </div>
          <div class="broker-meta-item">
            <div class="broker-meta-val">{{this.totalTrades}}</div>
            <div class="broker-meta-lbl">Trades</div>
          </div>
          <div class="broker-meta-item">
            <div class="broker-meta-val">{{this.totalClients}}</div>
            <div class="broker-meta-lbl">Clients</div>
          </div>
        </div>
        <a href="/brokers/{{this.id}}" class="btn btn-outline btn-sm mt-2" style="margin-top:1rem">View Profile</a>
      </div>
      {{else}}
      <div style="grid-column:1/-1;text-align:center;padding:3rem;color:var(--neutral-400)">No brokers listed yet</div>
      {{/each}}
    </div>
  </div>
</section>
